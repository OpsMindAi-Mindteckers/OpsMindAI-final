CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_FRONTEND_API=
DATABASE_URL=
GITHUB_TOKEN=
REDIS_URL=
OPENROUTER_API_KEY=
REFACTOR_MODEL=

# ── Monitoring (Grafana Cloud) ────────────────────────────────────────────────
# Sign up free at: https://grafana.com/auth/sign-up/create-user
# After sign-up → go to your stack → "Details" tab to find these URLs

# Grafana Cloud → Your Stack → Details → "Grafana" section → URL
GRAFANA_URL=

# Grafana Cloud → Your Stack → Details → "Prometheus" section → Query URL
# e.g. https://prometheus-prod-01-eu-west-0.grafana.net/api/prom
PROMETHEUS_URL=

# Grafana Cloud → Your Stack → Details → "Loki" section → URL
# e.g. https://logs-prod-eu-west-0.grafana.net
LOKI_URL=

# Grafana Cloud → Your Stack → "Access Policies" → create policy with metrics:write,logs:write,alerts:write
# Then create a token under that policy and paste it here
GRAFANA_API_KEY=
# Grafana instance Service Account token (for writing annotations)
# Get it from: https://opsmindai.grafana.net → Administration → Service Accounts → Create → Add token
GRAFANA_SERVICE_TOKEN=

# Grafana Cloud → Your Stack → Details → Prometheus section → "Username / Instance ID" (numeric)
PROMETHEUS_USER_ID=




# Grafana Cloud → Your Stack → Details → Loki section → "Username / Instance ID" (numeric)
LOKI_USER_ID=